{
  "manifest_version": 3,
  "name": "cleen2",
  "version": "0.1.0",
  "description": "Park tabs into saved stacks, reopen them later, and lighten Chrome with one-click cleanup.",
  "permissions": [
    "tabs",
    "storage"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "cleen2",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "minimum_chrome_version": "116"
}
